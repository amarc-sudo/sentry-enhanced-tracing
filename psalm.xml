<?xml version="1.0"?>
<psalm
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="https://getpsalm.org/schema/config"
    xsi:schemaLocation="https://getpsalm.org/schema/config vendor/vimeo/psalm/config.xsd"
    errorLevel="4"
    resolveFromConfigFile="true"
    rememberPropertyAssignmentsAfterCall="true"
    cacheDirectory="var/cache/psalm"
>
    <projectFiles>
        <directory name="src"/>
        <directory name="tests"/>
        <ignoreFiles>
            <directory name="vendor"/>
            <directory name="var"/>
        </ignoreFiles>
    </projectFiles>

    <issueHandlers>
        <!--
            Symfony 8.1's ViewEvent uses PHP 8.4 property hooks, which Psalm 6.x
            cannot parse yet, so it wrongly reports the class as undefined. The
            class exists at runtime (PHPStan and the test suite resolve it fine).
        -->
        <UndefinedClass>
            <errorLevel type="suppress">
                <referencedClass name="Symfony\Component\HttpKernel\Event\ViewEvent"/>
            </errorLevel>
        </UndefinedClass>

        <!-- Stylistic preferences, intentionally not enforced. -->
        <MissingOverrideAttribute errorLevel="suppress"/>
        <UnnecessaryVarAnnotation errorLevel="suppress"/>
        <RedundantCast errorLevel="suppress"/>

        <!--
            Bundle, listeners and subscribers are wired through Symfony DI and the
            event dispatcher, so Psalm's static reachability analysis cannot see
            their usages and reports false positives.
        -->
        <UnusedClass errorLevel="suppress"/>
        <PossiblyUnusedMethod errorLevel="suppress"/>
    </issueHandlers>

    <plugins>
        <pluginClass class="Psalm\SymfonyPsalmPlugin\Plugin"/>
    </plugins>
</psalm> 